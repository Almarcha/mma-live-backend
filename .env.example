# ============================================================
#  MMA Live · Variables de entorno
#  Copia este archivo como .env y rellena los valores
#  NUNCA subas .env a GitHub — ya está en .gitignore
# ============================================================

# ── SUPABASE ────────────────────────────────────────────────
# Encuéntralos en: Supabase → Project Settings → API

# URL del proyecto (formato: https://xxxxxxxxxxxx.supabase.co)
SUPABASE_URL=https://TU_PROYECTO.supabase.co

# Clave anon/public (para la API pública y el frontend)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...TU_ANON_KEY

# Clave service_role (SOLO para el scraper y operaciones admin — NUNCA en frontend)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...TU_SERVICE_KEY

# ── API ──────────────────────────────────────────────────────
# URL donde estará desplegada la API (para CORS)
API_URL=https://TU_APP.onrender.com

# URL del frontend
FRONTEND_URL=https://TU_USUARIO.github.io/mma-live
